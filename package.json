{
  "name": "upload-smith",
  "version": "2.0.1",
  "description": "Config-driven Multer utility for easy file uploads with extension-based validation, auto folder management, size limits, cleanup, and optional image compression",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "license": "MIT",
  "author": {
    "name": "Manan Patel",
    "email": "mananpatel1603@gmail.com",
    "url": "https://github.com/PatelManan1612/upload-smith"
  },
  "maintainers": [
    {
      "name": "Manan Patel",
      "email": "mananpatel1603@gmail.com"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PatelManan1612/upload-smith"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', '{\\\"type\\\":\\\"commonjs\\\"}')\"",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.974.0",
    "@azure/storage-blob": "^12.30.0",
    "@google-cloud/storage": "^7.18.0",
    "cloudinary": "^2.9.0",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "sharp": "^0.34.5"
  },
  "keywords": [
    "upload-smith",
    "upload",
    "multer",
    "file-upload",
    "express",
    "upload-middleware",
    "file-validation",
    "image-upload",
    "compression",
    "nodejs",
    "typescript",
    "esm",
    "cjs",
    "utility"
  ],
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "rimraf": "^6.1.2",
    "typescript": "^5.7.3"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
