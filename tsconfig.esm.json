{
  "compilerOptions": {
    "outDir": "dist/esm",
    "module": "ES2020",
    "moduleResolution": "Node",
    "target": "ES2019",
    "declaration": true,
    "declarationDir": "dist/types",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts", "*.ts"],
  "exclude": ["node_modules", "dist"]
}
